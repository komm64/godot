tint_sources = [tint_dir + f for f in tint_sources]

env_tint = env_webgpu.Clone()
env_tint.disable_warnings()

# Tint requires C++20.
if env_tint.get("is_msvc", False) or env.msvc:
    env_tint.Append(CXXFLAGS=["/std:c++20"])
else:
    env_tint.Append(CXXFLAGS=["-std=c++20"])

# Tint preprocessor defines: only enable SPIR-V reader + WGSL writer.
env_tint.Append(
    CPPDEFINES=[
        ("TINT_BUILD_SPV_READER", 1),
        ("TINT_BUILD_WGSL_WRITER", 1),
        ("TINT_BUILD_WGSL_READER", 0),
        ("TINT_BUILD_SPV_WRITER", 0),
        ("TINT_BUILD_GLSL_WRITER", 0),
        ("TINT_BUILD_HLSL_WRITER", 0),
        ("TINT_BUILD_MSL_WRITER", 0),
        ("TINT_BUILD_NULL_WRITER", 0),
        ("TINT_BUILD_SYNTAX_TREE_WRITER", 0),
        ("TINT_BUILD_IR_BINARY", 0),
    ]
)

env_tint.Prepend(
    CPPPATH=[
        tint_dir,  # For src/tint/... includes.
        tint_dir + "src/",  # Some internal includes use src/ prefix.
        # SPIRV-Tools and SPIRV-Headers (Tint parser includes them directly).
        spirv_tools_dir,  # For "source/opt/..." includes from Tint's SPIR-V reader.
        spirv_tools_dir + "source/",
        spirv_tools_dir + "include/",
        spirv_tools_dir + "generated/",
        spirv_headers_dir + "include/",
        spirv_headers_dir + "include/spirv/unified1/",  # For bare "DebugInfo.h" includes from SPIRV-Tools.
    ]
)

tint_obj = []
env_tint.add_source_files(tint_obj, tint_sources)

# Compile tint_wrapper.cpp in the Tint C++20 environment so that Tint's
# headers (which use std::span, C++20 concepts, etc.) never leak into the
# main Godot driver build (C++17).
env_tint_wrapper = env_tint.Clone()
env_tint_wrapper.add_source_files(tint_obj, ["#drivers/webgpu/tint_wrapper.cpp"])

# =============================================================================
# WebGPU driver sources
# =============================================================================

# Driver sources only need SPIRV-Tools/Headers for spirv_preprocess; they
# never include Tint headers directly (that goes through tint_wrapper.h).
env_webgpu.Prepend(
    CPPPATH=[
        spirv_tools_dir + "include/",
        spirv_headers_dir + "include/",
    ]
)

# Exclude tint_wrapper.cpp from the driver glob — it's compiled above in
# the Tint C++20 environment instead.
webgpu_sources = Glob("#drivers/webgpu/*.cpp")
webgpu_sources = [f for f in webgpu_sources if "tint_wrapper" not in str(f)]
env_webgpu.add_source_files(env.drivers_sources, webgpu_sources)

# Add thirdparty objects to the driver.
env.drivers_sources += spirv_tools_obj
env.drivers_sources += tint_obj

# Generate precompiled SPIR-V → WGSL lookup table at build time.
# The generated header is #included by rendering_device_driver_webgpu.cpp.
env.CommandNoCache(
    "#drivers/webgpu/wgsl_precompiled.gen.h",
    "#drivers/webgpu/wgsl_precompile.py",
    env.Run(wgsl_precompile.build_wgsl_precompiled),
)
